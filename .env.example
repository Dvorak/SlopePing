SKI_LOGIN_URL=https://allrounder-jobs.de/login
SKI_USERNAME=your_username
SKI_PASSWORD=your_password

# First version runs visibly for local debugging.
SKI_HEADLESS=false
SKI_SLOW_MO_MS=250
SKI_NAVIGATION_TIMEOUT_MS=30000

SKI_STATE_PATH=state.json
SKI_SCREENSHOTS_DIR=screenshots

# Notification channel: ntfy or console.
NOTIFY_CHANNEL=ntfy
# Test mode: send a notification on every successful run with current lessons
# and new lessons. Set to false for normal "new lessons only" behavior.
NOTIFY_ALWAYS_SEND_REPORT=false

# ntfy notification settings. Use a long private topic.
NTFY_SERVER=https://ntfy.sh
NTFY_TOPIC=your-private-topic

# Override these when the live HTML differs.
SKI_USERNAME_LABEL=Benutzername
SKI_PASSWORD_LABEL=Passwort
SKI_LOGIN_BUTTON_NAME=Anmelden
SKI_MY_DATA_TEXT=Meine Daten
SKI_SCHEDULE_TEXT=Arbeitsplan/Verfügbarkeit
SKI_OVERVIEW_TEXT=Übersicht
SKI_OVERVIEW_TABLE_XPATH=xpath=following::table[1]

# Webhook configuration for remote action triggers (mobile notifications)
# Generate a strong random token and keep it secret
ACTION_WEBHOOK_TOKEN=your-secret-webhook-token
# Base URL where the webhook service is accessible (e.g., http://192.168.1.100:8000)
ACTION_WEBHOOK_BASE_URL=http://localhost:8000
# Safe default: local machine only. Use 0.0.0.0 only on trusted networks.
WEBHOOK_HOST=127.0.0.1
WEBHOOK_PORT=8000
